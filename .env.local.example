# ===========================================
# LOCAL DEVELOPMENT - EVO Tap
# ===========================================
# Copy to .env.local: cp .env.local.example .env.local

# Environment
NODE_ENV=development
ENVIRONMENT=local

# ===========================================
# REQUIRED
# ===========================================

# Bot Token (from @BotFather)
BOT_TOKEN=your_bot_token_from_botfather

# Mini App URL
# For browser testing: http://localhost:3000
# For Telegram testing: Run `ngrok http 3000` and paste HTTPS URL
MINI_APP_URL=https://your-ngrok-url.ngrok-free.app

# ===========================================
# OPTIONAL (for local - required for prod)
# ===========================================

# Supabase (can skip for local-only testing)
SUPABASE_URL=https://your-dev-project.supabase.co
SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Redis (uses in-memory mock for local)
# UPSTASH_REDIS_URL=
# UPSTASH_REDIS_TOKEN=

# ===========================================
# TON
# ===========================================
TON_NETWORK=testnet
TON_CENTER_API_KEY=

# ===========================================
# VITE (exposed to browser)
# ===========================================
VITE_API_URL=http://localhost:8787
VITE_TON_NETWORK=testnet
VITE_ENVIRONMENT=local
