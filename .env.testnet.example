# ===========================================
# TESTNET DEPLOYMENT
# ===========================================

# Environment
NODE_ENV=production
ENVIRONMENT=testnet

# Bot Configuration
BOT_TOKEN=your_testnet_bot_token

# Supabase (staging project)
SUPABASE_URL=https://your-staging-project.supabase.co
SUPABASE_ANON_KEY=your_staging_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_staging_service_role_key

# URLs (staging)
MINI_APP_URL=https://staging.evotap.app
VITE_API_URL=https://api-staging.evotap.app

# TON Network
TON_NETWORK=testnet
TON_CENTER_API_KEY=your_toncenter_testnet_key

# Redis (required for staging)
UPSTASH_REDIS_URL=your_staging_redis_url
UPSTASH_REDIS_TOKEN=your_staging_redis_token

# Jetton Contract (testnet)
JETTON_MASTER_ADDRESS=
JETTON_WALLET_ADDRESS=
