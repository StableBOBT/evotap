# ===========================================
# MAINNET PRODUCTION
# ===========================================

# Environment
NODE_ENV=production
ENVIRONMENT=mainnet

# Bot Configuration
BOT_TOKEN=your_production_bot_token

# Supabase (production project)
SUPABASE_URL=https://your-production-project.supabase.co
SUPABASE_ANON_KEY=your_production_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_production_service_role_key

# URLs (production)
MINI_APP_URL=https://evotap.app
VITE_API_URL=https://api.evotap.app

# TON Network
TON_NETWORK=mainnet
TON_CENTER_API_KEY=your_toncenter_mainnet_key

# Redis (required for production)
UPSTASH_REDIS_URL=your_production_redis_url
UPSTASH_REDIS_TOKEN=your_production_redis_token

# Jetton Contract (mainnet)
JETTON_MASTER_ADDRESS=
JETTON_WALLET_ADDRESS=

# Monitoring (optional)
SENTRY_DSN=
