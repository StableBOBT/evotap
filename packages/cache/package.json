{
  "name": "@app/cache",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.js"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "import": "./dist/types.js"
    },
    "./rateLimiter": {
      "types": "./dist/rateLimiter.d.ts",
      "import": "./dist/rateLimiter.js"
    },
    "./leaderboard": {
      "types": "./dist/leaderboard.d.ts",
      "import": "./dist/leaderboard.js"
    },
    "./userCache": {
      "types": "./dist/userCache.d.ts",
      "import": "./dist/userCache.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "clean": "rm -rf dist node_modules"
  },
  "dependencies": {
    "@upstash/ratelimit": "^2.0.5",
    "@upstash/redis": "^1.34.3"
  },
  "devDependencies": {
    "tsup": "^8.3.5",
    "vitest": "^2.1.8",
    "@vitest/coverage-v8": "^2.1.8"
  }
}
