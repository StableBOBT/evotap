# =============================================================================
# EVO TAP - PRODUCTION ENVIRONMENT VARIABLES
# =============================================================================
# Copy this file to .env and fill in your values

# -----------------------------------------------------------------------------
# TELEGRAM BOT
# -----------------------------------------------------------------------------
BOT_TOKEN=your_bot_token_here
BOT_USERNAME=EVOtapBot

# -----------------------------------------------------------------------------
# UPSTASH REDIS (console.upstash.com)
# Go to: Database > Your DB > REST API > Copy these values
# -----------------------------------------------------------------------------
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_token_here

# -----------------------------------------------------------------------------
# API CONFIGURATION
# -----------------------------------------------------------------------------
API_URL=https://evo-api.your-domain.workers.dev
ENVIRONMENT=production

# -----------------------------------------------------------------------------
# MINI APP
# -----------------------------------------------------------------------------
VITE_API_URL=https://evo-api.your-domain.workers.dev
VITE_BOT_USERNAME=EVOtapBot
