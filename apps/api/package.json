    "@app/core": "workspace:*",
    "@app/database": "workspace:*",
    "@app/telegram": "workspace:*",
    "@hono/swagger-ui": "^0.5.0",
    "@hono/zod-openapi": "^0.18.3",
    "@hono/zod-validator": "^0.4.3",
    "@supabase/supabase-js": "^2.47.14",
    "hono": "^4.6.0",
    "zod": "^3.24.3"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241230.0",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^2.1.9",
    "wrangler": "^4.15.2"
  }
}
