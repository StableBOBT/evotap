{
  "name": "@app/bot",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "dev:local": "tsx scripts/dev.ts",
    "build": "tsup",
    "deploy:testnet": "wrangler deploy --env testnet",
    "deploy:mainnet": "wrangler deploy --env mainnet",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "grammy": "^1.32.0",
    "@grammyjs/runner": "^2.0.3",
    "@app/core": "workspace:*",
    "@app/database": "workspace:*",
    "@app/config": "workspace:*"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241230.0",
    "dotenv": "^16.4.7",
    "tsup": "^8.5.1",
    "tsx": "^4.19.2",
    "typescript": "^5.9.3",
    "vitest": "^2.1.9",
    "wrangler": "^4.15.2"
  }
}
